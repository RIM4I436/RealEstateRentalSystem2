<Window x:Class="RealEstateRentalSystem.Views.AddEditPropertyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="➕ Добавить объект" Height="550" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Адрес:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtAddress" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Text="Тип:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <ComboBox x:Name="cmbType" Grid.Row="1" Grid.Column="1" Margin="5" Height="30" SelectedIndex="0">
            <ComboBoxItem Content="Квартира"/>
            <ComboBoxItem Content="Дом"/>
            <ComboBoxItem Content="Офис"/>
            <ComboBoxItem Content="Коммерческая"/>
        </ComboBox>

        <TextBlock Text="Комнат:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtRooms" Grid.Row="2" Grid.Column="1" Margin="5" Height="30" Text="0"/>

        <TextBlock Text="Площадь (м²):" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtArea" Grid.Row="3" Grid.Column="1" Margin="5" Height="30" Text="0"/>

        <TextBlock Text="Этаж:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtFloor" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Text="Цена за месяц:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtPrice" Grid.Row="5" Grid.Column="1" Margin="5" Height="30" Text="0"/>

        <TextBlock Text="Описание:" Grid.Row="6" Grid.Column="0" VerticalAlignment="Top" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtDescription" Grid.Row="6" Grid.Column="1" Height="80" Margin="5" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="💾 Сохранить" Width="100" Height="35" Margin="10" 
                    Background="#27AE60" Foreground="White" FontWeight="Bold" Click="BtnSave_Click"/>
            <Button x:Name="btnCancel" Content="❌ Отмена" Width="100" Height="35" Margin="10" 
                    Background="#E74C3C" Foreground="White" FontWeight="Bold" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>