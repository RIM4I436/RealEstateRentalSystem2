<Window x:Class="RealEstateRentalSystem.Views.AddEditContractWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="➕ Добавить договор" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="ID объекта:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtPropertyId" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Text="ID клиента:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtClientId" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Text="Дата начала:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <DatePicker x:Name="dpStartDate" Grid.Row="2" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Text="Дата конца:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <DatePicker x:Name="dpEndDate" Grid.Row="3" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Text="Платёж/мес:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtMonthlyPayment" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="💾 Сохранить" Width="100" Height="35" Margin="10" 
                    Background="#27AE60" Foreground="White" FontWeight="Bold" Click="BtnSave_Click"/>
            <Button x:Name="btnCancel" Content="❌ Отмена" Width="100" Height="35" Margin="10" 
                    Background="#E74C3C" Foreground="White" FontWeight="Bold" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>