<Window x:Class="RealEstateRentalSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🏠 Система аренды недвижимости" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Стиль для навигационных кнопок -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#3498DB"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Стиль для TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Стиль для ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель навигации -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnProperties" Content="🏠 Объекты" 
                        Style="{StaticResource NavButtonStyle}" 
                        Background="#3498DB"
                        Click="BtnProperties_Click"/>

                <Button x:Name="btnClients" Content="👥 Клиенты" 
                        Style="{StaticResource NavButtonStyle}" 
                        Background="#27AE60"
                        Click="BtnClients_Click"/>

                <Button x:Name="btnContracts" Content="📄 Договоры" 
                        Style="{StaticResource NavButtonStyle}" 
                        Background="#8E44AD"
                        Click="BtnContracts_Click"/>
            </StackPanel>
        </Border>

        <!-- Панель поиска и фильтрации -->
        <Border Grid.Row="1" Background="#ECF0F1" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔍 Поиск:" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="14"/>
                <TextBox x:Name="txtSearch" Width="200" TextChanged="TxtSearch_TextChanged"/>

                <TextBlock Text="Тип:" VerticalAlignment="Center" Margin="20,0,5,0" FontSize="14"/>
                <ComboBox x:Name="cmbFilter" Width="120" SelectionChanged="CmbFilter_SelectionChanged">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="Квартира"/>
                    <ComboBoxItem Content="Дом"/>
                    <ComboBoxItem Content="Офис"/>
                    <ComboBoxItem Content="Коммерческая"/>
                </ComboBox>

                <Button x:Name="btnRefresh" Content="🔄 Обновить" 
                        Width="100" Height="30" Margin="20,0,0,0"
                        Background="#7F8C8D" Foreground="White" 
                        Cursor="Hand" Click="BtnRefresh_Click"/>
            </StackPanel>
        </Border>

        <!-- DataGrid для отображения данных -->
        <DataGrid x:Name="dgvData" Grid.Row="2" 
                  AutoGenerateColumns="True" 
                  IsReadOnly="True" 
                  SelectionMode="Single" 
                  SelectionUnit="FullRow"
                  AlternatingRowBackground="#F5F5F5" 
                  FontSize="13" 
                  Margin="10"
                  BorderBrush="#BDC3C7" 
                  BorderThickness="1">
            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3498DB" Opacity="0.7"/>
            </DataGrid.Resources>
        </DataGrid>

        <!-- Нижняя панель с кнопками действий -->
        <Border Grid.Row="3" Background="#ECF0F1" Padding="10" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnAdd" Content="➕ Добавить" 
                        Style="{StaticResource ActionButtonStyle}" 
                        Background="#27AE60"
                        Click="BtnAdd_Click"/>

                <Button x:Name="btnEdit" Content="✏️ Редактировать" 
                        Style="{StaticResource ActionButtonStyle}" 
                        Background="#F39C12"
                        Click="BtnEdit_Click"/>

                <Button x:Name="btnDelete" Content="🗑️ Удалить" 
                        Style="{StaticResource ActionButtonStyle}" 
                        Background="#E74C3C"
                        Click="BtnDelete_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>